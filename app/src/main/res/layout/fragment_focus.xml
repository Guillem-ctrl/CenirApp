<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <!-- Fondo decorativo superior (degradado) -->
    <View
        android:id="@+id/bgHeader"
        android:layout_width="0dp"
        android:layout_height="320dp"
        android:background="@drawable/gradient_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Etiqueta de estado -->
    <TextView
        android:id="@+id/tvSessionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LISTO"
        android:textSize="11sp"
        android:textColor="#CCFFFFFF"
        android:letterSpacing="0.2"
        android:textAllCaps="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp" />

    <!-- Contenedor del anillo — elevado sobre el degradado -->
    <FrameLayout
        android:id="@+id/ringContainer"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/bg_ring_shadow"
        app:layout_constraintTop_toBottomOf="@id/tvSessionLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <com.cenir.cenirapp.ui.focus.TimerRingView
            android:id="@+id/timerRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:text="25:00"
            android:textColor="#FF1A1A2E"
            android:textSize="52sp"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- Panel de controles (tarjeta flotante) -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_control_panel"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/ringContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp">

        <!-- Botones de duración preestablecida -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <Button
                android:id="@+id/btn25"
                style="?attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_duration_active"
                android:text="25 min"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn45"
                style="?attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/bg_duration_inactive"
                android:text="45 min"
                android:textColor="@color/ash"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn60"
                style="?attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_duration_inactive"
                android:text="60 min"
                android:textColor="@color/ash"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Campo tiempo personalizado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etCustomMinutes"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:hint="min"
                android:inputType="number"
                android:maxLength="3"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:textColor="@color/ink"
                android:textColorHint="@color/ash" />

            <Button
                android:id="@+id/btnCustomMinutes"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_duration_inactive"
                android:paddingHorizontal="16dp"
                android:text="Aplicar"
                android:textColor="@color/ash"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Botones Play/Pause y Reset -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_button_circle"
                android:contentDescription="Play/Pause"
                android:padding="16dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="#FFFFFFFF" />

            <Button
                android:id="@+id/btnReset"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Reiniciar"
                android:textColor="@color/ash"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
